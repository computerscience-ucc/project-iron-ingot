# =============================================================================
# UCC INGO -- Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored -- secrets stay local.
# =============================================================================

# --- Sanity CMS (Next.js public -- exposed to browser) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
NEXT_PUBLIC_SANITY_API_VERSION=2023-10-01

# --- Sanity Project Metadata ---
SANITY_ORGANIZATION_ID=
SANITY_PROJECT_TITLE=
SANITY_PROJECT_PLAN=

# --- Sanity API Tokens (gitignored -- never committed) ---
SANITY_TOKEN_ACCESS_MANAGER=
SANITY_TOKEN_BLUEPRINTS_DEPLOYER=
SANITY_DEPLOY_TOKEN=
SANITY_TOKEN_EDITOR=
SANITY_TOKEN_VIEWER=

# Active token for server-side dataset operations.
# Typically set to the Editor token value.
SANITY_API_TOKEN=

# --- Google Gemini (powers the CSBot chat widget) ---
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Facebook Messenger (Meta Graph API — server-only, no NEXT_PUBLIC_ prefix) ---
# Get these from https://developers.facebook.com → Your App → Messenger → Settings
FB_PAGE_ID=
FB_APP_SECRET=
FB_VERIFY_TOKEN=
FB_PAGE_ACCESS_TOKEN=
